# === LLM 配置（必填）===
# Qwen API Key
QWEN_API_KEY=your_api_key_here
# Qwen API 地址（使用 OpenAI 兼容接口）
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# Qwen 模型名称
QWEN_MODEL=qwen3.6-plus

# === LangSmith 链路追踪（可选）===
LANGCHAIN_TRACING_V2=false
LANGSMITH_API_KEY=
LANGCHAIN_PROJECT=GeneralistAgent

# === 本地嵌入模型路径（可选）===
BGE_M3_MODEL_PATH=

# === 远程技能存储（可选）===
# Skill 远程数据库目录（默认项目根目录下的 remote/skills/）
# SKILL_REMOTE_DB_DIR=./remote/skills