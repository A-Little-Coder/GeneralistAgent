# === LLM 配置（必填）===
# Qwen API Key
QWEN_API_KEY=your_api_key_here
# Qwen API 地址（使用 OpenAI 兼容接口）
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# Qwen 模型名称
QWEN_MODEL=qwen3.6-plus

# === LangSmith 链路追踪（可选）===
LANGCHAIN_TRACING_V2=false
LANGSMITH_API_KEY=
LANGCHAIN_PROJECT=GeneralistAgent

# === 本地嵌入模型路径（可选）===
BGE_M3_MODEL_PATH=

# === 远程技能存储（可选）===
# Skill 远程数据库目录（默认项目根目录下的 remote/skills/）
# SKILL_REMOTE_DB_DIR=./remote/skills

# === 外部代理 Agent 服务（可选，按 PROXY_<NAME>_* 命名）===
# 每个外部 Agent 服务需独立一组配置。NAME 为大写字母数字（实际服务名小写）
# ACCESS_KIND 取 http / nl2sql_sse / mcp；http 与 nl2sql_sse 必须填 BASE_URL
#
# 示例：NL2SQL 问数服务（D:\CodeProjects\PycharmProjects\NL2SQL\run_api.py）
PROXY_CHATBI_ACCESS_KIND=nl2sql_sse
PROXY_CHATBI_BASE_URL=http://127.0.0.1:8000
# 可选：服务无认证时留空；如启用 Bearer Token 在此填
# PROXY_CHATBI_AUTH_HEADER=Bearer your_token
PROXY_CHATBI_TIMEOUT=120
# 可选：自定义关联的 SKILL 名（默认 proxy_<name>）
# PROXY_CHATBI_SKILL_NAME=proxy_chatbi
#
# 示例：通用 HTTP 简单服务（POST /query + JSON 立返）
# PROXY_FOO_ACCESS_KIND=http
# PROXY_FOO_BASE_URL=http://localhost:9000
# PROXY_FOO_TIMEOUT=30
#
# 示例：基于 MCP 的服务（占位，待实现）
# PROXY_BAR_ACCESS_KIND=mcp
# PROXY_BAR_MCP_COMMAND=python -m bar_mcp_server